@inject AppStateService _appStateService
@inject ChatSettingsService _chatSettingsService
<div class="contact-settings-panel">
    <div class="settings-content">
        @switch (_currentView)
        {
            case View.Settings:
                <div class="sidebar-header"><h3>Ustawienia</h3></div>
                if (!_chatSettingsService.IsArchive)
                {
                    <button class="btn-secondary" @onclick="() => _currentView = View.ChangeName">Zmień nazwe czatu</button>
                    <button class="btn-secondary" @onclick="() => _currentView = View.Users">Uczestnicy</button>
                    <button class="btn-secondary" @onclick="LoadContactsAsync">Dodaj osoby</button>


                    @if (!_appStateService.CurrentChat.Identity.IsGroup)
                    {

                        <button class="btn-secondary btn-delete" @onclick='() => _chatSettingsService.RequestConfirmationActionAsync("Usuwanie", "Czy na pewno?", HandleContactDeleteAsync)'>Usuń kontakt</button>
                    }
                    else
                    {
                        <button class="btn-secondary" @onclick="() => _currentView = View.ChangePhoto">Zmień zdjecie grupy</button>
                        <button class="btn-secondary btn-delete" @onclick='() => _chatSettingsService.RequestConfirmationActionAsync("Opuszczanie", "Czy na pewno?", HandleChatLeaveAsync)'>Opuść czat</button>
                    }
                }
                @if (_chatSettingsService.IsArchive)
                {
                    <button class="btn-secondary btn-delete" @onclick='() => _chatSettingsService.RequestConfirmationActionAsync("Usuwanie", "Czy na pewno chcesz usunąć? Ta zmiana jest nieodwracalna!", HandleChatDeleteAsync)'>Usuń czat</button>
                }
                break;
            case View.AddUsers:
                <div class="sidebar-header"><h3>Dodaj osoby</h3></div>
                <div class="search-container">
                    <input type="text" class="form-control search-input" placeholder="Szukaj..."
                           @bind="_contactSearchTerm" @bind:event="oninput" />
                </div>
                <div class="search-results">
                    @if (FilteredContacts != null && FilteredContacts.Any())
                    {
                        @foreach (var user in FilteredContacts)
                        {
                            bool isSelected = ContactsToAdd.Contains(user.ContactUserID);
                            <div class="search-result-item @(isSelected ? "selected" : "")"
                                 @onclick="async () => await AddUserToSelectionAsync(user.ContactUserID)">
                                <div class="user-search-info">
                                    <img src="@user.AvatarUrl" class="user-avatar" />
                                    <span>@user.Username</span>
                                </div>
                            </div>
                        }
                    }
                </div>
                @if (ContactsToAdd != null && ContactsToAdd.Any())
                {
                    <button class="btn-add-action" @onclick="async () => { _currentView = View.Settings; await CreateGroupAsync(ContactsToAdd); }">Zatwierdź</button>
                }
                <button class="btn-add-action" @onclick="() => _currentView = View.Settings">Cofnij</button>
                break;

            case View.Users:
                <div class="sidebar-header"><h3>Uczestnicy</h3></div>
                @foreach (var user in ExistingUsers)
                {
                    <div class="search-result-item">
                        <div class="user-search-info">
                            <img src="@user.AvatarUrl" class="user-avatar" />
                            <span>@user.Username</span>
                        </div>
                    </div>
                }
                <button class="btn-add-action" @onclick="() => _currentView = View.Settings">Cofnij</button>
                break;
            case View.ChangeName:
                <div class="sidebar-header"><h3>Zmień nazwę czatu</h3></div>
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Nowa nazwa czatu..."
                           @bind="_newChatName" />
                </div>
                <button class="btn-primary" @onclick="async () => { _currentView = View.Settings; await HandleChatNameChangeAsync(_newChatName); }">Zatwierdź</button>
                <button class="btn-secondary" @onclick="() => _currentView = View.Settings">Cofnij</button>
                break;
            case View.ChangePhoto:
                <div class="sidebar-header"><h3>Zmień zdjęcie grupy</h3></div>
                <div class="group-avatar-container">
                <ImageComponent AvatarUrl="@_appStateService.CurrentChat.Identity.AvatarUrl"
                                    Name="@_appStateService.CurrentChat.Identity.ChatName"
                                LabelRole="Grupa"
                                IsGroup="true" />
                <button class="btn-secondary" @onclick="() => _currentView = View.Settings">Cofnij</button>
                </div>

                break;
        }
    </div>
</div>

@code {
        public List<ContactDTO> UserContacts => _chatSettingsService.ReceivedContacts;
    public HashSet<UserDTO> ExistingUsers => _chatSettingsService.UsersInChat;
    public HashSet<Guid> ContactsToAdd { get; set; } = new();

    private enum View { Settings, AddUsers, Users, ChangeName, ChangePhoto }
    private View _currentView = View.Settings;
    private string _contactSearchTerm = string.Empty;
    private string _newChatName = string.Empty;
    private IEnumerable<ContactDTO> FilteredContacts =>
       UserContacts?.Where(c =>
           (string.IsNullOrWhiteSpace(_contactSearchTerm) ||
            c.Username.Contains(_contactSearchTerm, StringComparison.OrdinalIgnoreCase))
           &&
           !ExistingUsers.Any(u => u.UserID == c.ContactUserID)
       ) ?? Enumerable.Empty<ContactDTO>();
    private async Task AddUserToSelectionAsync(Guid contactId)
    {
        if (ContactsToAdd.Contains(contactId))
        {
            ContactsToAdd.Remove(contactId);
        }
        else
        {
            ContactsToAdd.Add(contactId);
        }
        await Task.CompletedTask;
    }
    private async Task CreateGroupAsync(HashSet<Guid> usersToAdd)
    {
        _currentView = View.Settings;
        await _chatSettingsService.RequestCreateGroupChatAsync(usersToAdd);
        ContactsToAdd.Clear();
    }
    private async Task HandleChatNameChangeAsync(string name)
    {
        if (!string.IsNullOrWhiteSpace(name))
        {
            _currentView = View.Settings;
            await _chatSettingsService.RequestChatNameChangeAsync(name);

        }
    }

    private async Task HandleContactDeleteAsync()
    {
        _currentView = View.Settings;
        await _chatSettingsService.RequestContactDeleteChangeAsync();

    }
    private async Task LoadContactsAsync()
    {
        await _chatSettingsService.RequestLoadContactsAsync();
        _currentView = View.AddUsers;

    }

    private async Task HandleChatLeaveAsync()
    {
        //IsSettingsOpen = false;
        await _chatSettingsService.RequestChatLeaveAsync();
    }

    private async Task HandleChatDeleteAsync()
    {
        //IsSettingsOpen = false;
        await _chatSettingsService.RequestChatDeleteAsync();

    }
}

@using ChatApp.Application.Interfaces
@inject AppStateService AppState
<aside class="sidebar">
    <div class="sidebar-header">
        <div class="user-info-wrapper">
            <p class="user-detail">Witaj,@(AppState?.CurrentUser?.Username ?? String.Empty)</p>
            <p class="user-icon" title="openProfile "onclick="@OpenProfile">👤</p>
        </div>
        <div class="nav-tabs">
            <button class="@(currentView == View.Contacts ? "active" : "")" @onclick="() => currentView = View.Contacts">
                Kontakty
            </button>
            <button class="@(currentView == View.Invites ? "active" : "")" @onclick="() => currentView = View.Invites">
                Zaproszenia @(PendingInvitesCount > 0 ? $"({PendingInvitesCount})" : "")
            </button>
        </div>

        @if (currentView == View.Contacts)
        {
            <div class="search-container">
                <input type="text" class="form-control search-input"
                       placeholder="Szukaj na liście..."
                       @bind="searchTerm"
                       @bind:event="oninput" />
            </div>
        }
    </div>

    <div class="sidebar-content">
        @switch (currentView)
        {
            case View.Contacts:
                <div class="contacts-list">
                    @if (SidebarItem == null || !FilteredSidebar.Any())
                    {
                        <p class="section-hint">Nie znaleziono kontaktów.</p>
                    }
                    else
                    {
                        @foreach (var chat in FilteredSidebar)
                        {
                            <div class="contact-item @(SelectedContactId == chat.ChatID ? "active" : "")"
                                 @onclick="async () => await SelectContact(chat.ChatID)">
                                <div class="contact-avatar-container">
                                    <img src="@chat.AvatarUrl" class="contact-img" alt="avatar" />
                                </div>
                                <div class="contact-info">
                                    <p class="contact-name">@chat.ChatName</p>
                                    @if(chat.LastMessageContent != null)
                                    {
                                    <p class="contact-name">
                                        @((chat.LastMessageSender == AppState.CurrentUser.Username)
                                                                ? $"Ty: {chat.LastMessageContent}"
                                                                : $"{chat.LastMessageSender}: {chat.LastMessageContent}")
                                    </p>
                                        
                                    }
                                    @if(chat.UnreadMessageCount > 0)
                                    {
                                        <p class="contact-name">@chat.UnreadMessageCount nowe wiadomości!</p>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
                break;
            case View.Invites:
                <div class="invites-list">
                    <div class="empty-state-container">
                        @if(!InvitesList.Any())
                        {
                            <p class="section-hint">Brak nowych zaproszeń.</p>
                        }
                        else
                        {
                            @foreach(var invite in InvitesList)
                            {
                                <div class="invite-item">
                                    <div class="invite-info">
                                        <img src="@invite.SenderAvatarUrl" class="invite-avatar" alt="avatar" />
                                        <span class="invite-username">@invite.SenderUsername</span>
                                    </div>
                                    <div class="invite-actions">
                                        <button class="btn-accept" @onclick="() => HandleInviteResponse(invite.InviteID, true)">
                                            Akceptuj
                                        </button>
                                        <button class="btn-decline" @onclick="() => HandleInviteResponse(invite.InviteID, false)">
                                            Odrzuć
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
                break;
            case View.AddContact:
                <div class="add-contact-view">
                    <h4 class="view-title">Znajdź użytkownika</h4>
                    <div class="search-container">
                        <input type="text" class="form-control search-input"
                               placeholder="Wpisz nazwę użytkownika..."
                               @bind="globalSearchQuery"
                               @bind:event="oninput"
                               @onkeyup="OnGlobalSearchInput" />
                    </div>

                    <div class="search-results">
                        @if (IsSearching)
                        {
                            <div class="loading-spinner-container">
                                <p class="section-hint">Szukanie "@globalSearchQuery"...</p>
                            </div>
                        }
                        else if (UsersList != null && UsersList.Any())
                        {
                            @foreach (var user in UsersList)
                            {
                                <div class="search-result-item">
                                    <div class="contacts-info">
                                        <img src="@user.AvatarUrl" class="user-avatar" />
                                        <span class="search-username">@user.Username</span>
    
                                    </div>
                                    <button disabled="@isPending" class="btn-add-action" @onclick="() => SendInvite(user.UserID)">
                                        Dodaj
                                    </button>
                                </div>
                            }
                        }
                        else if (!string.IsNullOrEmpty(globalSearchQuery) && globalSearchQuery.Length >= 3)
                        {
                            <p class="section-hint">Nie znaleziono użytkownika.</p>
                        }
                        else
                        {
                            <p class="section-hint">Wpisz min. 3 znaki, aby wyszukać.</p>
                        }
                    </div>
                </div>
                break;
        }
    </div>
    <div class="sidebar-footer">
        @if (currentView != View.AddContact)
        {
            <button class="btn-add-contact" @onclick="() => currentView = View.AddContact">
                <span class="plus-icon">+</span> Dodaj kontakt
            </button>
        }
        else
        {
            <button class="btn-secondary" @onclick="() => currentView = View.Contacts">
                Anuluj i wróć
            </button>
        }
    </div>
</aside>

@code {
    #region Parameters
    [Parameter] public EventCallback<string> OnSearchRequested { get; set; }
    [Parameter] public EventCallback<ContactSelectedArgs> OnContactSelected { get; set; }
    [Parameter] public EventCallback<Guid> OnContactInvited { get; set; }
    [Parameter] public EventCallback<(Guid InviteId,bool Status)> OnInviteAction { get; set; }
    [Parameter] public EventCallback<bool> OnProfileOpen { get; set; }
    [Parameter] public List<UserChatDTO> SidebarItem { get; set; } = new List<UserChatDTO>();
    [Parameter] public List<UserDTO> UsersList { get; set; } = new List<UserDTO>();
    [Parameter] public List<InviteDTO> InvitesList { get; set; } = new List<InviteDTO>();
    [Parameter] public bool IsSearching { get; set; }
    [Parameter] public bool isPending { get; set;  }
    #endregion
    #region Variables
    private enum View { Contacts, Invites, AddContact }
    private View currentView = View.Contacts;
    private string searchTerm = "";
    private string globalSearchQuery = "";
    private int PendingInvitesCount => InvitesList?.Count ?? 0;
    protected Guid SelectedContactId;
    #endregion
    protected override void OnParametersSet()
    {
        StateHasChanged();
    }
    private IEnumerable<UserChatDTO> FilteredSidebar =>
        SidebarItem?.Where(c => string.IsNullOrWhiteSpace(searchTerm) ||
                               c.ChatName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        ?? Enumerable.Empty<UserChatDTO>();
    private async Task SelectContact(Guid contactId)
    {
        SelectedContactId = contactId;
        await OnContactSelected.InvokeAsync(new ContactSelectedArgs(contactId));
    }
    private async Task OnGlobalSearchInput()
    {
        if (string.IsNullOrWhiteSpace(globalSearchQuery) || globalSearchQuery.Length < 3)
        {
            UsersList?.Clear();
            return;
        }

        await OnSearchRequested.InvokeAsync(globalSearchQuery);
    }
    private async Task HandleInviteResponse(Guid InviteId,bool Response)
    {
        await OnInviteAction.InvokeAsync((InviteId,Response));
    }
    private async Task OpenProfile()
    {
        await OnProfileOpen.InvokeAsync(true);
    }
    private async Task SendInvite(Guid targetUserId)
    {
        isPending = true;
        await OnContactInvited.InvokeAsync(targetUserId);
        globalSearchQuery = "";
    }
}
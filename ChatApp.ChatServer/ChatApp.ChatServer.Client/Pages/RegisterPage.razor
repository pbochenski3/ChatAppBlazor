@page "/register"
@inject IConfiguration Configuration
@inject NavigationManager NavManager
@inject ChatHubService ChatHubService
@inject AppStateService AppState
@implements IDisposable

<EditForm Model="@userDTO" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />
    @if (!string.IsNullOrEmpty(notification))
    {
        <div class="notification-toast">
            <div>@notification</div>
        </div>
    }
    <div class="form-group">
        <label>Enter username:</label>
        <InputText @bind-Value="userDTO.Username" class="form-control" disabled="@isProcessing" maxlength="20" />
        <label>Enter password:</label>
        <InputText type="password" @bind-Value="userDTO.Password" class="form-control" disabled="@isProcessing" maxlength="128"/>
    </div>

    <button type="submit"
            class="btn btn-primary mt-2"
            disabled="@isProcessing">
        @if (isProcessing)
        {
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        }
        else
        {
            <span>Register</span>
        }
    </button>
</EditForm>

@code {
    private bool isProcessing = false;
    string notification = string.Empty;
    protected override async Task OnInitializedAsync()
    {
        ChatHubService.RegisterStatusMessage += HandleRegisterNotification;
    }
    private UserDTO userDTO = new UserDTO();

    private void HandleRegisterNotification(string message)
    {
        notification = message;
        if (message.Equals("User registered successfully."))
        {
            userDTO = new UserDTO();
            AppState.Message = "Registered successfully!";
            NavManager.NavigateTo("/");
            return;
        }
        isProcessing = false;
        InvokeAsync(StateHasChanged);
    }
    private async Task HandleSubmit()
    {
        isProcessing = true;
        try
        {
            await ChatHubService.RegisterUserAsync(userDTO);
        }
        catch (Exception ex)
        {
            notification = $"{ex.Message}";
            isProcessing = false;
            InvokeAsync(StateHasChanged);
        }
    }
    public void Dispose()
    {
        ChatHubService.RegisterStatusMessage -= HandleRegisterNotification;
    }
}
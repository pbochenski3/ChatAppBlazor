@page "/register"
@inject IConfiguration Configuration
@inject NavigationManager NavManager
@inject ChatHubService ChatHubService
@inject AppStateService AppState
@implements IDisposable
@if (!string.IsNullOrEmpty(notification))
{
    <div class="notification-toast">
        <div>@notification</div>
    </div>
}
<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <span class="logo-dot"></span>
            <h1>Rejestracja</h1>
        </div>
        <p class="login-subtitle">Załóż nowe konto</p>

        <EditForm Model="@userDTO" OnValidSubmit="HandleSubmit">

            <div class="field-group">
                <label class="field-label">Nazwa użytkownika</label>
                <InputText @bind-Value="userDTO.Username"
                           class="field-input"
                           disabled="@isProcessing"
                           maxlength="20"
                           placeholder="Wpisz nazwe użytkownika" />
            
            </div>

            <div class="field-group">
                <label class="field-label">Hasło</label>
                <InputText type="password"
                           @bind-Value="userDTO.Password"
                           class="field-input"
                           disabled="@isProcessing"
                           maxlength="128"
                           placeholder="Wpisz hasło" />
             
            </div>

            <button type="submit" class="btn-login" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="spinner"></span>
                    <span>Rejestracja...</span>
                }
                else
                {
                    <span>Zarejestruj się</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <span>Masz już konto?</span>
            <a href="/login">Zaloguj się</a>
        </div>
    </div>
</div>
@code {
    private bool isProcessing = false;
    string notification = string.Empty;
    protected override async Task OnInitializedAsync()
    {
        ChatHubService.RegisterStatusMessage += HandleRegisterNotification;
    }
    private UserDTO userDTO = new UserDTO();

    private void HandleRegisterNotification(string message)
    {
        notification = message;
        if (message.Equals("User registered successfully."))
        {
            userDTO = new UserDTO();
            AppState.Message = "Registered successfully!";
            NavManager.NavigateTo("/");
            return;
        }
        isProcessing = false;
        InvokeAsync(StateHasChanged);
    }
    private async Task HandleSubmit()
    {
        isProcessing = true;
        try
        {
            await ChatHubService.RegisterUserAsync(userDTO);
        }
        catch (Exception ex)
        {
            notification = $"{ex.Message}";
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    public void Dispose()
    {
        ChatHubService.RegisterStatusMessage -= HandleRegisterNotification;
    }
}
@page "/register"
@inject IConfiguration Configuration
@inject NavigationManager NavManager
@inject ChatHubService ChatHubService
@inject AppStateService AppState
@implements IDisposable

@if (!string.IsNullOrEmpty(_notification))
{
    <div class="notification-toast">
        <div>@_notification</div>
    </div>
}

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <span class="logo-dot"></span>
            <h1>Rejestracja</h1>
        </div>
        <p class="login-subtitle">Załóż nowe konto</p>

        <EditForm Model="@_registerModel" OnValidSubmit="HandleRegisterAsync">
            <div class="field-group">
                <label class="field-label">Nazwa użytkownika</label>
                <InputText @bind-Value="_registerModel.Username"
                           class="field-input"
                           disabled="@_isProcessing"
                           maxlength="20"
                           placeholder="Wpisz nazwę użytkownika" />
            </div>

            <div class="field-group">
                <label class="field-label">Hasło</label>
                <InputText type="password"
                           @bind-Value="_registerModel.Password"
                           class="field-input"
                           disabled="@_isProcessing"
                           maxlength="128"
                           placeholder="Wpisz hasło" />
            </div>

            <button type="submit" class="btn-login" disabled="@_isProcessing">
                @if (_isProcessing)
                {
                    <span class="spinner"></span>
                    <span>Rejestracja...</span>
                }
                else
                {
                    <span>Zarejestruj się</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <span>Masz już konto?</span>
            <a href="/">Zaloguj się</a>
        </div>
    </div>
</div>

@code {
    private bool _isProcessing = false;
    private string? _notification = string.Empty;
    private UserDTO _registerModel = new UserDTO();

    protected override async Task OnInitializedAsync()
    {
        ChatHubService.RegisterStatusMessage += HandleRegisterNotification;
    }

    private void HandleRegisterNotification(string message)
    {
        _notification = message;
        if (message.Equals("User registered successfully."))
        {
            _registerModel = new UserDTO();
            AppState.Message = "Registered successfully!";
            NavManager.NavigateTo("/");
            return;
        }
        _isProcessing = false;
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleRegisterAsync()
    {
        _isProcessing = true;
        try
        {
            await ChatHubService.RegisterUserAsync(_registerModel);
        }
        catch (Exception ex)
        {
            _notification = $"{ex.Message}";
            _isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        ChatHubService.RegisterStatusMessage -= HandleRegisterNotification;
    }
}

@page "/hub"
@using ChatApp.Application
@using Microsoft.AspNetCore.SignalR.Client
@using ChatApp.ChatServer.Client.Components
@inject IConfiguration Configuration
@inject NavigationManager NavManager
@inject ChatHubService ChatHubService
@inject AppStateService AppState
@implements IAsyncDisposable
@inject ILogger<BlazorHub> _logger
@if(isLoading == false)
{
<div class="main-layout">
    <ContactsComponent 
        OnSearchRequested="HandleGlobalSearch"
        OnContactInvited="HandleContactInvite"
        OnContactSelected= "HandleChatLoad"
        OnInviteAction="@(args => HandleContactStatus(args.InviteId, args.Status))"
        SidebarItem="SidebarItems"
        UsersList="foundUsers"
        InvitesList="receivedInvites"
        IsSearching="isSearchingGlobal"
        isPending="isPending"
        />
       
    <main class="chat-content">
        @if (!string.IsNullOrEmpty(notification))
        {
            <div class="notification-toast">
                <div>@notification</div>
            </div>
        }
        @if (AppState.CurrentChat != null)
        {
   
        <ChatComponent
            OnSendMessage="HandleSendMessage"
            OnDeleteContact="HandleContactDelete"
            Messages="receivedMessage"
            IsLocked="lockChat"
            IsArchive="isArchive"
            OnAddUserTriggered="HandleContactLoad"
            OnAddUserClick="HandleCreateGroupChat"
            OnChatLeave="HandleChatLeave"
            userContacts="receivedContacts"
            ExistingUsers="usersInChat"
        />
        }
    </main>
</div>
}
@code {
    private CancellationTokenSource? _chatLoadingCts;
    private string? notification = string.Empty;
    UserDTO user = new UserDTO();
    private List<MessageDTO> receivedMessage = new List<MessageDTO>();
    private List<InviteDTO> receivedInvites = new List<InviteDTO>();
    private List<ChatDTO> receivedChats = new List<ChatDTO>();
    private List<ContactDTO> receivedContacts = new List<ContactDTO>();
    private List<UserDTO> foundUsers = new List<UserDTO>();
    private HashSet<UserDTO> usersInChat = new HashSet<UserDTO>();
    private List<UserChatDTO> SidebarItems = new List<UserChatDTO>();
    private bool isSearchingGlobal = false;
    private bool isPending;
    private bool lockChat = true;
    private bool isArchive = false;
    bool isLoading = true;
    private Guid ChatId;
    private int counter;
    private bool isChatLoaded;

    protected override async Task OnInitializedAsync()
    {
        if (AppState.CurrentUser == null)
        {
            NavManager.NavigateTo("/");
            return;
        }
        ;
        user = AppState.CurrentUser;
        notification = AppState.Message;
        if (!string.IsNullOrEmpty(notification))
        {
            AppState.Message = null;
            _ = ShowNotification(notification);
        };

        ChatHubService.OnAppReload += HandleUnifiedReload;
        ChatHubService.OnMessageReceived += HandleReceiveMessage;
        ChatHubService.InviteStatusMessage += OnInviteStatusReceived;
        ChatHubService.OnChatLoad += HandleChatLoad;
        var StartHub = ChatHubService.StartAsync();
        var DataReload = HandleDataReload(true);
        try
        {
            await Task.WhenAll(StartHub, DataReload);
            isLoading = false;
        }
        catch (Exception ex)
        {
            _ = ShowNotification($"{ex.Message}");
        }
    }
    private async Task OnInviteStatusReceived(string status,Guid contactId)
    {
        CancellationToken token = default;
        var chatTask = ChatHubService.GetChatInformation(contactId, token);
        var notifyTask = ShowNotification(status);
        await Task.WhenAll(chatTask, notifyTask);
    }
    private async Task HandleUnifiedReload(ReloadTarget target)
    {
        await InvokeAsync(async () =>
     {
         switch (target)
         {
             case ReloadTarget.Sidebar:
                 await HandleSidebarLoad(true);
                 break;
             case ReloadTarget.Invite:
                 await HandleInviteLoad(true);
                 break;
             case ReloadTarget.Global:
                 await HandleDataReload(true);
                 break;

         }
         StateHasChanged();
     });
    }
    private async Task HandleGlobalSearch(string query)
    {
        isSearchingGlobal = true;
        foundUsers = await ChatHubService.GetUsersToInviteAsync(query);
        isSearchingGlobal = false;
        StateHasChanged();
    }
    private async Task ShowNotification(string message, int durationInSeconds = 5)
    {
        notification = message;
        await InvokeAsync(StateHasChanged); 

        await Task.Delay(durationInSeconds * 1000); 

        notification = string.Empty;
        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleDataReload(bool reload)
    {
        if (reload)
        {
            await HandleInviteLoad(reload);
            await HandleSidebarLoad(reload);
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task HandleInviteLoad(bool reload)
    {
        if (true)
        {
            receivedInvites = await ChatHubService.GetInvitesAsync();
            isPending = false;
            await InvokeAsync(StateHasChanged);
            _logger.LogInformation($"Invite reload triggered for user {AppState.CurrentUser.Username}");
        }
    }
    private async Task HandleSidebarLoad(bool reload)
    {
        try
        {
            SidebarItems = await ChatHubService.LoadSidebarItems();
            _logger.LogInformation($"Sidebar reloaded. Items count: {SidebarItems.Count}");
            isPending = false;
        }
        catch (Exception ex)
        {
            _logger.LogError($"Błąd podczas odświeżania Sidebaru {ex}");
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task HandleContactInvite(Guid contactId)
    {
        await ChatHubService.SendInviteAsync(contactId);
        foundUsers.RemoveAll(u => u.UserID == contactId);
        isSearchingGlobal = false;
    }
    private async Task HandleContactDelete()
    {
        try
        {
            await ChatHubService.DeleteContactAsync(AppState.CurrentChat.ChatID);

        }
        catch (Exception ex)
        {
            _ = ShowNotification($"{ex.Message}");
        }
    }
    private async Task HandleChatLeave()
    {
        try
        {
            await ChatHubService.LeaveGroupChat(AppState.CurrentChat.ChatID);

        }
        catch (Exception ex)
        {
            _ = ShowNotification($"{ex.Message}");
        }
    }
    private async Task HandleContactStatus(Guid InviteId,bool Status)
    {
        try
        {
            await ChatHubService.SendInviteActionAsync(InviteId, Status);
        }
        catch (Exception ex)
        {
            _ = ShowNotification($"{ex.Message}");
        }
    }
    private async Task HandleContactLoad()
    {
        try
        {
            receivedContacts = await ChatHubService.GetContactList();
            _logger.LogInformation($"Kontakty załadowane");
        }
        catch(Exception ex)
        {;
            _logger.LogError($"Bład podczas ładowania konatkrów {ex}");
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }

    }
    private async Task HandleReceiveMessage(MessageDTO dto)
    {
        bool isMessageForCurrentChat = AppState.CurrentChat != null && dto.ChatID == AppState.CurrentChat.ChatID;
        if (isMessageForCurrentChat)
        {
            receivedMessage.Add(dto);
            await InvokeAsync(StateHasChanged);

            if (dto.SenderID != user.UserID)
            {
                try
                {
                    await ChatHubService.MarkMessageAsReaded(dto.ChatID, dto.MessageID);
                }
                catch (Exception ex)
                {
                    _logger.LogWarning(ex, "Failed to mark message as read for ChatId: {ChatId}, MessageId: {MessageId}", dto.ChatID, dto.MessageID);
                }
            }
        }
        else
        {
            if (dto.SenderID != user.UserID)
            {
                await HandleCounterUpdate(dto.ChatID,false);
            }
        }
    }
    private async Task HandleCounterUpdate(Guid chatId, bool clean)
    {
        var index = SidebarItems.FindIndex(sb => sb.ChatID == chatId);

        if (index != -1)
        {
            if (clean)
            {
                SidebarItems[index].counter = 0;
                _logger.LogInformation($"Licznik wyzerowany dla: {chatId}");
            }
            else
            {
                var updatedItem = SidebarItems[index];
                updatedItem.counter += 1;

                SidebarItems.RemoveAt(index);
                SidebarItems.Insert(0, updatedItem);

                _logger.LogInformation($"Licznik zwiększony dla: {chatId}. Aktualnie: {updatedItem.counter}");
            }
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task HandleSendMessage(string content)
    {
        if (string.IsNullOrWhiteSpace(content)) return;

        var newMessage = new MessageDTO
        {
            Content = content,
            SenderUsername = user.Username,
            ChatID = AppState.CurrentChat.ChatID,
            SenderID = user.UserID, 
            SentAt = DateTime.UtcNow,
            MessageID = Guid.CreateVersion7()
        };

        try
        {
            await ChatHubService.SendMessageAsync(newMessage,AppState.CurrentChat.ChatID);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Błąd wysyłki");
            receivedMessage.Remove(newMessage);
            _ = ShowNotification("Nie udało się wysłać wiadomości.");
        }
    }
    private async Task HandleChatLoad(ContactSelectedArgs args)
    {
        _chatLoadingCts?.Cancel();
        _chatLoadingCts = new CancellationTokenSource();
        var token = _chatLoadingCts.Token;
        try
        {
            bool isSameChat = (AppState.CurrentChat?.ChatID == args.ChatId);


            if (!isSameChat || (isSameChat && args.Force))
            {
                isChatLoaded = false;
                receivedMessage = new List<MessageDTO>();
                _logger.LogInformation("Switching to chat: {Id}", args.ChatId);
            }
            var chatInformation = await ChatHubService.GetChatInformation(args.ChatId, token);
                try
                {
                usersInChat = await ChatHubService.GetGroupUsers(chatInformation.ChatID);
                    _logger.LogInformation("[BLAZORHUB]Existing User Loading Succes");

                }
                catch
                {
                    _logger.LogInformation("[BLAZORHUB]Existing User Loading Failed");
                }

            token.ThrowIfCancellationRequested();


            if (chatInformation == null)
            {
                _logger.LogError("[BLAZORHUB]Chat could not be loaded for ID: {Id}", args.ChatId);
                return;
            }

            if (!isSameChat || receivedMessage.Count == 0 || (isSameChat && args.Force))
            {
                receivedMessage = await ChatHubService.GetPrivateHistory(chatInformation.ChatID,token);

                if (token.IsCancellationRequested) return;
            }
            AppState.CurrentChat = chatInformation;
            isArchive = chatInformation.IsArchive;
            lockChat = chatInformation.IsArchive;

            if (!chatInformation.IsArchive)
            {
                await ChatHubService.JoinGroupSignal(AppState.CurrentChat.ChatID);
                await ChatHubService.MarkChatMessagesAsReaded(chatInformation.ChatID,token);
                if(token.IsCancellationRequested) return;
                await HandleCounterUpdate(chatInformation.ChatID, true);
            }

            isChatLoaded = true;
        }
        catch (OperationCanceledException)
        {
            _logger.LogInformation("Chat loading cancelled for {Id}", args.ChatId);
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error when trying to load chat {Id}", args.ChatId);
            _ = ShowNotification("Błąd podczas ładowania czatu.");
        }
        finally
        {
            if (!_chatLoadingCts.IsCancellationRequested)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
    }
    private async Task HandleCreateGroupChat(HashSet<Guid> usersToAdd)
    {
        var exist = await ChatHubService.CheckIfGroupExist(AppState.CurrentChat.ChatID);
        if(exist)
        {
            await ChatHubService.AddUserToGroup(AppState.CurrentChat.ChatID, usersToAdd);
        }
        else
        {
            await ChatHubService.CreateChatGroup(AppState.CurrentChat.ChatID, usersToAdd);
        }
    }
    private async Task HandleChatUsersLoad()
    {
        await ChatHubService.GetGroupUsers(AppState.CurrentChat.ChatID);
        await InvokeAsync(StateHasChanged);
    }
    public async ValueTask DisposeAsync()
    {
        ChatHubService.OnMessageReceived -= HandleReceiveMessage;
        ChatHubService.InviteStatusMessage -= OnInviteStatusReceived;
        ChatHubService.OnAppReload -= HandleUnifiedReload;
        ChatHubService.OnChatLoad -= HandleChatLoad;
    }
}
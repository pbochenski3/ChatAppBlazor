@page "/"
@inject IConfiguration Configuration
@inject NavigationManager NavManager
@inject ChatHubService ChatHubService
@inject AppStateService AppState
@implements IDisposable

@if (!string.IsNullOrEmpty(_notification))
{
    <div class="notification-toast">
        <div>@_notification</div>
    </div>
}

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <span class="logo-dot"></span>
            <h1>Logowanie</h1>
        </div>
        <p class="login-subtitle">Zaloguj się do swojego konta</p>

        <EditForm Model="@_loginModel" OnValidSubmit="HandleLoginAsync">
            <div class="field-group">
                <label class="field-label">Nazwa użytkownika</label>
                <InputText @bind-Value="_loginModel.Username"
                           class="field-input"
                           disabled="@_isProcessing"
                           maxlength="20"
                           placeholder="Wprowadź nazwę" />
            </div>

            <div class="field-group">
                <label class="field-label">Hasło</label>
                <InputText type="password"
                           @bind-Value="_loginModel.Password"
                           class="field-input"
                           disabled="@_isProcessing"
                           maxlength="128"
                           placeholder="Wprowadź hasło" />
            </div>

            <button type="submit" class="btn-login" disabled="@_isProcessing">
                @if (_isProcessing)
                {
                    <span class="spinner"></span>
                    <span>Logowanie...</span>
                }
                else
                {
                    <span>Zaloguj się</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <span>Nie masz konta?</span>
            <a href="/register">Zarejestruj się</a>
        </div>
    </div>
</div>

@code {
    private bool _isProcessing = false;
    private string? _notification = string.Empty;
    private UserDTO _loginModel = new UserDTO();

    protected override async Task OnInitializedAsync()
    {
        _notification = AppState.Message;
        AppState.Message = null;
        ChatHubService.LoginStatusMessage += HandleLoginNotification;
    }

    private void HandleLoginNotification(string message, UserDTO user)
    {
        _notification = message;
        _isProcessing = false;
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleLoginAsync()
    {
        _notification = string.Empty;
        _isProcessing = true;
        StateHasChanged();
        try
        {
            _isProcessing = true;
            var response = await _httpClient.PostAsJsonAsync("api/auth/login", _loginModel);
            if(response.IsSuccessStatusCode)
            {
                AppState.CurrentUser = await response.Content.ReadFromJsonAsync<UserDTO>();
                _loginModel = new UserDTO();
                AppState.Message = "Logged in successfully!";
                NavManager.NavigateTo("/hub");
            }

        }
        catch (Exception ex)
        {
            _notification = $"{ex.Message}";
        }
    }

    public void Dispose()
    {
        ChatHubService.LoginStatusMessage -= HandleLoginNotification;
    }
}

@page "/"
@inject IConfiguration Configuration
@inject NavigationManager NavManager
@inject ChatHubService ChatHubService
@inject AppStateService AppState
@implements IDisposable
@if (!string.IsNullOrEmpty(notification))
{
    <div class="notification-toast">
        <div>@notification</div>
    </div>
}

<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <span class="logo-dot"></span>
            <h1>Logowanie</h1>
        </div>
        <p class="login-subtitle">Zaloguj sie do swojego konta</p>

        <EditForm Model="@userDTO" OnValidSubmit="HandleLogin">
            <div class="field-group">
                <label class="field-label">Nazwa użytkownika</label>
                <InputText @bind-Value="userDTO.Username"
                           class="field-input"
                           disabled="@isProcessing"
                           maxlength="20"
                           placeholder="Wprowadź nazwe" />
            </div>

            <div class="field-group">
                <label class="field-label">Hasło</label>
                <InputText type="password"
                           @bind-Value="userDTO.Password"
                           class="field-input"
                           disabled="@isProcessing"
                           maxlength="128"
                           placeholder="Wprowadź hasło" />
            </div>

            <button type="submit" class="btn-login" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="spinner"></span>
                    <span>Logowanie...</span>
                }
                else
                {
                    <span>Zaloguj się</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <span>Nie masz konta?</span>
            <a href="/register">Zarejestruj sie</a>
        </div>
    </div>
</div>
@code {
    bool isProcessing = false;
    string? notification = string.Empty;
    override protected async Task OnInitializedAsync()
    {
        notification = AppState.Message;
        AppState.Message = null;
        ChatHubService.LoginStatusMessage += HandleLoginNotification;
    }
    private UserDTO userDTO = new UserDTO();
    private void HandleLoginNotification(string message,UserDTO user)
    {
        notification = message;
        if (message.Equals("Success"))
        {
            AppState.Message = "Logged in successfully!";
            AppState.CurrentUser = user;
            userDTO = new UserDTO();
            NavManager.NavigateTo("/hub");
        }
        isProcessing = false;
        InvokeAsync(StateHasChanged);
    }
    private async Task HandleLogin()
    {
        notification = string.Empty;
        isProcessing = true;
        StateHasChanged();
        try
        {
            await ChatHubService.LoginUserAsync(userDTO);
        }
        catch (Exception ex)
        {
            notification = $"{ex.Message}";
        }
        finally
        {
            isProcessing = false;
            await InvokeAsync(StateHasChanged);
        }
    }
   public void Dispose()
    {
        ChatHubService.LoginStatusMessage -= HandleLoginNotification;
    }   
}
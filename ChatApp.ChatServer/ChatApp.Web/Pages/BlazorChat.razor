@page "/hub"
@using ChatApp.Application.DTO.Requests
@using ChatApp.ChatServer.Client.Services.Actions
@implements IAsyncDisposable
@inject ILogger<BlazorChat> _logger
@inject SidebarStateService _sidebarStateService
@inject SidebarActionService _sidebarActionService
@inject ChatActionService _chatActionService
@inject ChatStateService _chatStateService
@inject SidebarStateService _sidebarStateService

@if (_isLoading == false)
{
    <div class="toast-container">
        @if (!string.IsNullOrEmpty(_notification))
        {
            <div class="notification-toast">
                <div>@_notification</div>
            </div>
        }
    </div>
    <main class="main-layout">
        <SidebarComponent 
            OnSearchRequested="HandleGlobalSearch"
            OnContactInvited="HandleContactInvite"
            OnContactSelected="_chatActionService.HandleChatLoadAsync"
            OnProfileOpen="HandleOpenProfile"
            OnInviteAction="HandleContactStatus"/>
       
        @if (_appStateService.CurrentChat != null)
        {
            <ChatComponent/>
        }
        @if(_appStateService.IsProfileOpen)
        {
            <ImageComponent
                AvatarUrl="@_appStateService.CurrentUser.AvatarUrl"
                Name="@_appStateService.CurrentUser.Username"
                LabelRole="Użytkownik"
                IsGroup="false"/>
            <button class="btn-secondary" @onclick="() => _appStateService.Logout()">Zamknij profil</button>
        }
    </main>
}

@code {
    #region Private Fields
    private string? _notification = string.Empty;
    private UserDTO _currentUser = new UserDTO();
    private bool _isLoading = true;

    #endregion

    protected override async Task OnInitializedAsync()
    {
        if (_appStateService.CurrentUser == null)
        {
            _navManager.NavigateTo("/");
            return;
        }
        await _chatHubService.StartAsync();

        _currentUser = _appStateService.CurrentUser;
        _notification = _appStateService.Message;

        if (!string.IsNullOrEmpty(_notification))
        {
            _appStateService.Message = null;
            _ = ShowNotificationAsync(_notification);
        }

        try
        {
            await _chatHubService.StartAsync();
            SubscribeToEvent();
            await HandleDataReloadAsync(true);
            _isLoading = false;
        }
        catch (Exception ex)
        {
            _logger.LogError(ex, "Error during initialization");
            _ = ShowNotificationAsync($"{ex.Message}");
            _appStateService.CurrentUser = null;
            _navManager.NavigateTo("/");
            return;
        }
    }
    private void SubscribeToEvent()
    {
        _chatHubService.OnAppReload += HandleUnifiedReloadAsync;
        //_chatHubService.OnMessageReceived += HandleReceiveMessageAsync;
        _chatHubService.InviteStatusMessage += HandleInviteStatusReceivedAsync;
       // _chatHubService.OnChatLoad += HandleChatLoadAsync;
       // _chatHubService.OnUserInChatReload += HandleUserOnGroupLoadAsync;
        _chatHubService.OnChatNameChanged += HandleChatNameReloadAsync;
        //_chatHubService.OnLastMessageChanged += HandleSidebarMessageReloadAsync;
        _chatHubService.OnAvatarReload += HandleAvatarReloadAsync;
        _chatHubService.OnGroupAvatarReload += HandleGroupAvatarReloadAsync;

    }
    private void UnSubscribeToEvent()
    {
        _chatHubService.OnAppReload -= HandleUnifiedReloadAsync;
        //_chatHubService.OnMessageReceived -= HandleReceiveMessageAsync;
        _chatHubService.InviteStatusMessage -= HandleInviteStatusReceivedAsync;
        //_chatHubService.OnChatLoad -= HandleChatLoadAsync;
        _chatHubService.OnUserInChatReload -= HandleUserOnGroupLoadAsync;
        _chatHubService.OnChatNameChanged -= HandleChatNameReloadAsync;
        //_chatHubService.OnLastMessageChanged -= HandleSidebarMessageReloadAsync;
        _chatHubService.OnAvatarReload -= HandleAvatarReloadAsync;
        _chatHubService.OnGroupAvatarReload -= HandleGroupAvatarReloadAsync;

    }
    private async Task HandleOpenProfile(bool open)
    {
        _appStateService.CurrentChat = null;
        _appStateService.IsProfileOpen = open;
        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleInviteStatusReceivedAsync(string status)
    {
        var notifyTask = ShowNotificationAsync(status);
    }
    private async Task HandleUnifiedReloadAsync(ReloadTarget target)
    {
        await InvokeAsync(async () =>
        {
            switch (target)
            {
                case ReloadTarget.Sidebar:
                    await _sidebarActionService.HandleSidebarLoadAsync(true);
                    break;
                case ReloadTarget.Invite:
                    await HandleInviteLoadAsync(true);
                    break;
                case ReloadTarget.Global:
                    await HandleDataReloadAsync(true);
                    break;
                case ReloadTarget.Chat:
                    await _chatActionService.HandleChatClose(true);
                    break;
            }
            StateHasChanged();
        });
    }

    private async Task ShowNotificationAsync(string message, int durationInSeconds = 5)
    {
        _notification = message;
        await InvokeAsync(StateHasChanged); 

        await Task.Delay(durationInSeconds * 1000); 

        _notification = string.Empty;
        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleDataReloadAsync(bool reload)
    {
        if (reload)
        {
            await HandleInviteLoadAsync(reload);
            await _sidebarActionService.HandleSidebarLoadAsync(reload);
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task HandleGroupAvatarReloadAsync(string newAvatarUrl, Guid chatId)
    {
        var chatToUpdate = _sidebarStateService.SidebarItems.FirstOrDefault(sb => sb.Identity.ChatID == chatId);
        if (chatToUpdate != null)
        {
            chatToUpdate.Identity.AvatarUrl = newAvatarUrl;
        }
        if (_appStateService.CurrentChat != null && _appStateService.CurrentChat.Identity.ChatID == chatId)
        {
            _appStateService.CurrentChat.Identity.AvatarUrl = newAvatarUrl;
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleAvatarReloadAsync(string newAvatarUrl,Guid userId)
    {
        _appStateService.CurrentUser.AvatarUrl = newAvatarUrl;
        var userInChat = _chatStateService.UsersInChat.FirstOrDefault(u => u.UserID == userId);
        if (userInChat != null)
        {
            userInChat.AvatarUrl = newAvatarUrl;
        }
        if(_appStateService.CurrentUser.UserID == userId)
        {
            _appStateService.CurrentUser.AvatarUrl = newAvatarUrl;
        }

        if (_sidebarStateService.SidebarItems != null && _sidebarStateService.SidebarItems.Any())
        {
            var item = _sidebarStateService.SidebarItems.FirstOrDefault(sb => !sb.Identity.IsGroup && sb.Identity.OtherUserId == userId);
            if (item != null)
            {
                item.Identity.AvatarUrl = newAvatarUrl;
            }
        }
        await InvokeAsync(StateHasChanged);
    }
    private async Task HandleChatNameReloadAsync(Guid chatId, string newChatName)
    {
        var chat = _sidebarStateService.SidebarItems.FirstOrDefault(c => c.Identity.ChatID == chatId);
        if (chat != null)
        {
            chat.Identity.ChatName = newChatName;
        }
        if(_appStateService.CurrentChat != null && _appStateService.CurrentChat.Identity.ChatID == chatId)
        {
            _appStateService.CurrentChat.Identity.ChatName = newChatName;
        }
        await InvokeAsync(StateHasChanged);

    }
    private async Task HandleUserOnGroupLoadAsync(Guid chatId)
    {
        if (_appStateService.CurrentChat?.Identity.ChatID != chatId)
        {
            return;
        }
        try
        {
            _chatStateService.UsersInChat = await _groupChatApiClient.GetChatUsersAsync(chatId);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            _logger.LogWarning(ex, "[BLAZORHUB] Failed to load users for chat {Id}", chatId);
        }
    }
    // private async Task HandleChatUsersLoadAsync()
    // {
    //     if (_appStateService.CurrentChat != null)
    //     {
    //         await _groupChatApiClient.GetChatUsersAsync(_appStateService.CurrentChat.Identity.ChatID);
    //     }
    // }
    public async ValueTask DisposeAsync()
    {
        UnSubscribeToEvent();
    }
}

@using ChatApp.Domain.Models
@using System.Collections.Concurrent
@implements IDisposable

<div class="toast-container">
    @foreach (var note in _activeNotifications.Keys.ToList())
    {
        <div class="notification-toast @note.Type.ToString().ToLower()" @key="note">
            <p>@note.Message</p>
        </div>
    }
</div>

@code {
    private ConcurrentDictionary<NotificationMessage, byte> _activeNotifications = new();
    private bool _isDisposed;

    protected override void OnInitialized()
    {
        _notificationService.OnShow += HandleNotification;
    }

    private void HandleNotification(NotificationMessage note)
    {
        if (_isDisposed) return;

        if (_activeNotifications.TryAdd(note, 0))
        {
            InvokeAsync(StateHasChanged);
            _ = RemoveAfterDelay(note);
        }
    }

    private async Task RemoveAfterDelay(NotificationMessage note)
    {
        await Task.Delay(5000);

        if (_isDisposed) return;

        if (_activeNotifications.TryRemove(note, out _))
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
        _notificationService.OnShow -= HandleNotification;
    }
}
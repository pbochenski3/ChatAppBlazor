@using ChatApp.Domain.Models
@implements IDisposable

<div class="toast-container">
    @foreach (var note in _activeNotifications.ToList())
    {
        <div class="notification-toast @note.Type.ToString().ToLower()">
            <p>@note.Message</p>
        </div>
    }
</div>

@code {
    private List<NotificationMessage> _activeNotifications = new();
    private readonly object _lock = new();
    private bool _isDisposed;

    protected override void OnInitialized()
    {
        _notificationService.OnShow += HandleNotification;
    }

    private void HandleNotification(NotificationMessage note)
    {
        lock (_lock)
        {
            _activeNotifications.Add(note);
        }

        InvokeAsync(StateHasChanged);
        _ = RemoveAfterDelay(note);
    }

    private async Task RemoveAfterDelay(NotificationMessage note)
    {
        await Task.Delay(5000);

        if (_isDisposed) return;

        lock (_lock)
        {
            _activeNotifications.Remove(note);
        }

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _isDisposed = true;
        _notificationService.OnShow -= HandleNotification;
    }
}
@implements IDisposable;
<div class="chat-messages">
    @if (_chatStateService.ReceivedMessages != null && _chatStateService.ReceivedMessages.Any())
    {
        @foreach (var msg in _chatStateService.ReceivedMessages)
        {

            <div @key="msg.MessageID"
                 class="message @(IsSystem(msg) ? "system" : "") @(IsMyMessage(msg) ? "mine" : "")">
                @if (HasImage(msg.imageUrl))
                {
                    <img src="@msg.imageUrl" @onclick="() => _chatStateService.ToogleImageZoom(msg.imageUrl)" class="chat-image" />
                }
                <div class="message-row">
                    @if (!IsSystem(msg) && !IsMyMessage(msg))
                    {
                        <div class="message-info">
                            <span class="message-time">[@msg.SentAt.ToString("HH:mm")]</span>
                            @{
                                var sender = _chatStateService.UsersInChat.FirstOrDefault(u => u.Username == msg.SenderUsername);
                                var displayName = sender?.Alias ?? msg.SenderUsername;
                            }
                            <span class="message-user">@displayName:</span>
                        </div>
                    }
                    @if (HasText(msg.Content))
                            @if (_editingMessageId == msg.MessageID)
                            {
                                <div class="edit-container">
                                    <input @bind="_editText" @bind:event="oninput" class="edit-input" />
                                    <button @onclick="() => SaveEdit(msg)" class="btn-save">Zapisz</button>
                                    <button @onclick="CancelEditing" class="btn-cancel">Anuluj</button>
                                </div>
                            }
                            else
                            {
                                <MessageMenu
                                    OnEditClicked="() => StartEditing(msg)" 
                                    OnDeleteClicked="() => DeleteMessage(msg)"/>
                                <span class="message-content @(msg.IsDeleted ? "deleted" : "")">@LinkParser.Parse(msg.Content, _navManager.BaseUri)</span>

                                @if (msg.IsEdited)
                                {
                                    <span class="message-edit-note"> (edytowano)</span>
                                }
                        }
                </div>
            </div>
        }
    }
</div>

@code {
    private bool IsMyMessage(MessageDTO msg) => msg.SenderUsername == _appStateService.CurrentUser?.Username;
    private bool IsSystem(MessageDTO msg) => msg.MessageType == MessageType.System;
    private bool HasImage(string msg) => !string.IsNullOrWhiteSpace(msg);
    private bool HasText(string msg) => !string.IsNullOrWhiteSpace(msg);
    @code {
        private Guid? _editingMessageId; 
        private string _editText = string.Empty;

        protected override async Task OnInitializedAsync()
        {
            _chatStateService.OnStateChanged += HandleStateChanged;
            _chatMessageActionService.OnStateChanged += HandleStateChanged;
        }
        private async void HandleStateChanged()
        {
            await InvokeAsync(StateHasChanged);
        }

        private void StartEditing(MessageDTO msg)
        {
            _editingMessageId = msg.MessageID;
            _editText = msg.Content; 
        }

        private void CancelEditing()
        {
            _editingMessageId = null;
            _editText = string.Empty;
        }

        private async Task SaveEdit(MessageDTO msg)
        {
            if (string.IsNullOrWhiteSpace(_editText) || _editText == msg.Content)
            {
                CancelEditing();
                return;
            }
            msg.Content = _editText;
            await _chatMessageActionService.RequestMessageEdited(msg.MessageID, msg.ChatID, msg.Content);
            CancelEditing();
        }
        private async Task DeleteMessage(MessageDTO msg)
        {
            await _chatMessageActionService.RequestMessageDeleted(msg.MessageID, msg.ChatID);

        }
        public void Dispose()
        {
            _chatStateService.OnStateChanged -= HandleStateChanged;
            _chatMessageActionService.OnStateChanged -= HandleStateChanged;

        }
    }
}

@page "/register"


<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <span class="logo-dot"></span>
            <h1>Rejestracja</h1>
        </div>
        <p class="login-subtitle">Załóż nowe konto</p>

        <EditForm Model="@_registerModel" OnValidSubmit="HandleRegisterAsync">
            <div class="field-group">
                <label class="field-label">Nazwa użytkownika</label>
                <InputText @bind-Value="_registerModel.Username"
                           class="field-input"
                           disabled="@_isProcessing"
                           maxlength="20"
                           placeholder="Wpisz nazwę użytkownika" />
            </div>

            <div class="field-group">
                <label class="field-label">Hasło</label>
                <InputText type="password"
                           @bind-Value="_registerModel.Password"
                           class="field-input"
                           disabled="@_isProcessing"
                           maxlength="128"
                           placeholder="Wpisz hasło" />
            </div>

            <button type="submit" class="btn-login" disabled="@_isProcessing">
                @if (_isProcessing)
                {
                    <span class="spinner"></span>
                    <span>Rejestracja...</span>
                }
                else
                {
                    <span>Zarejestruj się</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <span>Masz już konto?</span>
            <a href="/">Zaloguj się</a>
        </div>
    </div>
</div>

@code {
    private bool _isProcessing = false;
    private UserDTO _registerModel = new UserDTO();

    protected override async Task OnInitializedAsync()
    {
        if (_appStateService.CurrentUser != null)
        {
            _navManager.NavigateTo("/hub");
        }
    }

    private async Task HandleRegisterAsync()
    {
        StateHasChanged();
        try
        {
            _isProcessing = true;
            await _authService.RegisterUserAsync(_registerModel);
            _notificationService.Notify("Rejestracja przebiegła pomyślnie!", NotificationType.Info);
            _navManager.NavigateTo("/");

        }
        catch (Exception ex)
        {
            _notificationService.Notify(ex.Message,NotificationType.Warning);
            _isProcessing = false;
        }
        finally
        {
            _isProcessing = false;
            StateHasChanged();
        }
    }
}

@page "/"
<div class="login-page">
    <div class="login-card">
        <div class="login-header">
            <span class="logo-dot"></span>
            <h1>Logowanie</h1>
        </div>
        <p class="login-subtitle">Zaloguj się do swojego konta</p>

        <EditForm Model="@_loginModel" OnValidSubmit="HandleLoginAsync">
            <div class="field-group">
                <label class="field-label">Nazwa użytkownika</label>
                <InputText @bind-Value="_loginModel.Username"
                           class="field-input"
                           disabled="@_isProcessing"
                           maxlength="20"
                           placeholder="Wprowadź nazwę" />
            </div>

            <div class="field-group">
                <label class="field-label">Hasło</label>
                <InputText type="password"
                           @bind-Value="_loginModel.Password"
                           class="field-input"
                           disabled="@_isProcessing"
                           maxlength="128"
                           placeholder="Wprowadź hasło" />
            </div>

            <button type="submit" class="btn-login" disabled="@_isProcessing">
                @if (_isProcessing)
                {
                    <span class="spinner"></span>
                    <span>Logowanie...</span>
                }
                else
                {
                    <span>Zaloguj się</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <span>Nie masz konta?</span>
            <a href="/register">Zarejestruj się</a>
        </div>
    </div>
</div>

@code {
    private bool _isProcessing = false;
    private string? _notification = string.Empty;
    private UserDTO _loginModel = new UserDTO();

    protected override async Task OnInitializedAsync()
    {
        if (_appStateService.CurrentUser != null)
        {
            _navManager.NavigateTo("/hub");
        }
        _notification = _appStateService.Message;
        _notification = string.Empty;
    }

    private async Task HandleLoginAsync()
    {
        _notification = string.Empty;
        _isProcessing = true;
        try
        {
            _isProcessing = true;
            await _authService.LoginUserAsync(_loginModel);

            if (_appStateService.CurrentUser != null)
            {
                _navManager.NavigateTo("/hub");

            }
            else
            {
                _notificationService.Notify("Logowanie się nie powiodło!", NotificationType.Warning);
                StateHasChanged();
            }

        }
        catch (Exception ex)
        {
            _notification = $"{ex.Message}";
        }
        finally
        {
            _isProcessing = false;
        }
    }

}
